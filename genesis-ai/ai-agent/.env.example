# AI Agent 环境配置

# AI 服务
OPENAI_API_KEY=your_openai_api_key
COZE_API_KEY=your_coze_api_key
COZE_BOT_ID=your_coze_bot_id

# 区块链 RPC（Polygon zkEVM 主网）
POLYGON_ZKEVM_RPC_URL=https://rpc.public.zkevm.net

# 交易配置
PRIVATE_KEY=your_trading_wallet_private_key
VAULT_ADDRESS=your_vault_contract_address

# 风险配置
RISK_LEVEL=medium
MAX_LEVERAGE=3
MAX_POSITIONS=3
AUTO_TRADING=false

# 策略配置
STRATEGIES=trend_following,mean_reversion
CHECK_INTERVAL_SECONDS=60

# 日志
LOG_LEVEL=INFO
